{
  "specVersion": 1,
  "id": "MedianFilter",
  "title": "Median Filter",
  "description": "Apply an N-D median filter to a volumetric image. Smooths noise while preserving edges. Backed by SimpleITK.",
  "parameters": [
    {
      "kind": "sourceRef",
      "id": "inputVolume",
      "title": "Input Volume",
      "help": "Input volume (DICOM, NIfTI, NRRD, MHA, etc.)",
      "section": "IO",
      "order": 0,
      "required": true,
      "accepts": [
        "image"
      ]
    },
    {
      "kind": "int",
      "id": "radius",
      "title": "Radius",
      "help": "Median filter radius (voxels).",
      "section": "Filter parameters",
      "order": 1,
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    }
  ],
  "outputs": [
    {
      "id": "outputVolume",
      "title": "Output Volume",
      "help": "Filtered output volume.",
      "type": "image",
      "format": ".nii.gz"
    }
  ]
}
