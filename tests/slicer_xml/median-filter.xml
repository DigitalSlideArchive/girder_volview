<?xml version="1.0" encoding="UTF-8"?>
<executable>
  <category>Radiology</category>
  <title>Median Filter</title>
  <description>Apply an N-D median filter to a volumetric image. Smooths noise while preserving edges. Backed by SimpleITK.</description>
  <version>0.1.0</version>
  <license>Apache 2.0</license>
  <contributor>VolView</contributor>
  <parameters>
    <label>IO</label>
    <description>Input/output parameters.</description>
    <image>
      <name>inputVolume</name>
      <label>Input Volume</label>
      <channel>input</channel>
      <description>Input volume (DICOM, NIfTI, NRRD, MHA, etc.)</description>
      <index>0</index>
    </image>
    <image fileExtensions=".nii.gz" reference="inputVolume">
      <name>outputVolume</name>
      <label>Output Volume</label>
      <channel>output</channel>
      <description>Filtered output volume.</description>
      <index>1</index>
    </image>
  </parameters>
  <parameters>
    <label>Filter parameters</label>
    <description>Tuning.</description>
    <integer>
      <name>radius</name>
      <label>Radius</label>
      <description>Median filter radius (voxels).</description>
      <longflag>radius</longflag>
      <default>1</default>
      <constraints>
        <minimum>1</minimum>
        <maximum>10</maximum>
        <step>1</step>
      </constraints>
    </integer>
  </parameters>
  <parameters advanced="true">
    <label>Girder API</label>
    <description>Server access injected by slicer_cli_web for v1 b3 feeding; not shown to users.</description>
    <string>
      <name>girderApiUrl</name>
      <longflag>girderApiUrl</longflag>
      <label>Girder API URL</label>
      <description>Girder API URL (injected by slicer_cli_web).</description>
      <default></default>
    </string>
    <string>
      <name>girderToken</name>
      <longflag>girderToken</longflag>
      <label>Girder Token</label>
      <description>Girder token (injected by slicer_cli_web).</description>
      <default></default>
    </string>
  </parameters>
</executable>
