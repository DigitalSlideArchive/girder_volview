{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "error": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "success",
        "error",
        "cancelled"
      ]
    }
  },
  "required": [
    "error"
  ],
  "additionalProperties": false
}
