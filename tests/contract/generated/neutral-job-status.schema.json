{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "jobId": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "success",
        "error",
        "cancelled"
      ]
    },
    "progress": {
      "type": "number"
    },
    "errorTail": {
      "type": "string"
    }
  },
  "required": [
    "jobId",
    "state"
  ],
  "additionalProperties": false
}
