{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "jobId": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "inputUris": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "finishedAt": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "success",
        "error",
        "cancelled"
      ]
    }
  },
  "required": [
    "jobId",
    "taskId",
    "inputUris",
    "finishedAt"
  ],
  "additionalProperties": false
}
