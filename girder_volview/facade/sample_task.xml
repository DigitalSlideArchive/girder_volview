<?xml version="1.0" encoding="UTF-8"?>
<executable>
  <category>Segmentation</category>
  <title>Threshold Segmentation</title>
  <description>Label voxels whose intensity falls between two thresholds.</description>
  <version>0.1.0</version>
  <license>Apache 2.0</license>
  <contributor>VolView</contributor>
  <parameters>
    <label>IO</label>
    <description>Input/output parameters.</description>
    <image>
      <name>inputVolume</name>
      <label>Input Volume</label>
      <channel>input</channel>
      <description>Volume to threshold</description>
      <longflag>input</longflag>
    </image>
    <image type="label">
      <name>outputVolume</name>
      <label>Output Segmentation</label>
      <channel>output</channel>
      <description>Binary labelmap of in-range voxels</description>
      <longflag>output</longflag>
    </image>
  </parameters>
  <parameters>
    <label>Threshold</label>
    <description>Intensity window to label.</description>
    <integer>
      <name>lowerThreshold</name>
      <label>Lower Threshold</label>
      <description>Lowest intensity to include (inclusive)</description>
      <longflag>lower</longflag>
      <default>50</default>
    </integer>
    <integer>
      <name>upperThreshold</name>
      <label>Upper Threshold</label>
      <description>Highest intensity to include (inclusive)</description>
      <longflag>upper</longflag>
      <default>65535</default>
    </integer>
  </parameters>
</executable>
